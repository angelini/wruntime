package ecommerce:client@0.1.0;

// A long-running worker: the engine calls `run` once and waits for it to return.
// Intentionally does NOT export wasi:http/incoming-handler so the engine
// falls through to the run-export path rather than the HTTP handler path.
world client {
    import wasi:cli/stderr@0.2.0;
    import wasi:io/error@0.2.0;
    import wasi:io/poll@0.2.0;
    import wasi:io/streams@0.2.0;
    import wasi:http/types@0.2.0;
    import wasi:http/outgoing-handler@0.2.0;

    export run: func();
}
